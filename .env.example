# AI caption generation (Anthropic Claude Sonnet 4.6)
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-api-key-here

# GoHighLevel — used for image uploads AND direct post scheduling (no Zapier needed)
GHL_API_KEY=your-ghl-api-key-here
GHL_LOCATION_ID=your-ghl-location-id-here
GHL_USER_ID=your-ghl-user-id-here

# Password gate — protects the app from unauthenticated access
APP_PASSWORD=your-password-here

# CORS pin (production only) — leave unset for local dev, set to your deployed URL in Railway
# Example: ALLOWED_ORIGIN=https://roofpost.yourcompany.co.uk
ALLOWED_ORIGIN=

# Where to find these in GHL:
# GHL_API_KEY     → Settings → Private Integrations (PIT — Bearer token)
#                   Required scopes:
#                     medias.write, medias.readonly,
#                     socialplanner/account.readonly, socialplanner/post.write
# GHL_LOCATION_ID → Settings → Business Info (or URL bar inside sub-account)
# GHL_USER_ID     → Settings → My Staff → click your user → "id" in URL
#                   (the post will be attributed to this user)
